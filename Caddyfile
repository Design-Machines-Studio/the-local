# ═══════════════════════════════════════════════════════════
# The Local — Caddy reverse proxy
# Handles TLS automatically via Let's Encrypt
# ═══════════════════════════════════════════════════════════

# ─── Root domain: Element Web + .well-known ──────────────
thelocal.chat {
	# Matrix server discovery
	handle /.well-known/matrix/* {
		root * /srv
		file_server
		header Content-Type application/json
		header Access-Control-Allow-Origin *
	}

	# Element Web client (everything else)
	handle {
		reverse_proxy element:80
	}
}

# ─── Matrix homeserver API + LiveKit ─────────────────────
matrix.thelocal.chat {
	# LiveKit JWT auth service
	handle /livekit/jwt/* {
		reverse_proxy jwt:8080
	}

	# LiveKit SFU WebSocket
	handle /livekit/sfu/* {
		reverse_proxy livekit:7880
	}

	# Synapse client-server + federation API
	# 120s timeouts needed for Element X sliding sync long-polling
	handle {
		reverse_proxy synapse:8008 {
			transport http {
				read_timeout 120s
				write_timeout 120s
			}
		}
	}

	request_body {
		max_size 50MB
	}
}
